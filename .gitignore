# Raw data files — too large for GitHub (5.15 GB total)
# Download from NYC Open Data links in README
data/NYC_ASSAULTS_THEFTS/*.csv
data/NYC_ROAD_ACCIDENTS/*.csv
data/NYC_FIRE_INCIDENTS/*.csv

# Cleaned data — regenerated by running the Rmd files
outputs/assaults_thefts/*_cleaned.csv
outputs/road_accidents/*_cleaned.csv
outputs/fire_incidents/*_cleaned.csv

# KEEP test result CSVs and the combined results
!outputs/assaults_thefts/Assaults_Thefts_Test_Results.csv
!outputs/road_accidents/Road_Accidents_Test_Results.csv
!outputs/fire_incidents/Fire_Incidents_Test_Results.csv
!outputs/combined/ALL_33_Nonparametric_Test_Results.csv

